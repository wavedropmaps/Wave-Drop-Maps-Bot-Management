  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json\\ntry:\\n  d=json.load(sys.stdin); f=d.get('tool_input',d).get('file_path',''); sys.exit(1 if any(x in f for x in ['config.json','credentials.json','tunnel_credentials.json']) else 0)\\nexcept: sys.exit(0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ai-hub/gates/validate.py || python ai-hub/gates/validate.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ai-hub/scripts/goals_status.py || python ai-hub/scripts/goals_status.py"
          }
        ]
      }
    ]
  }
