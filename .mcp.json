{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "camofox": {
      "command": "node",
      "args": [
        "./mcp-camofox-server.js"
      ],
      "env": {
        "CAMOFOX_API_KEY": "local-dev-key-change-in-production"
      }
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "@mksglu/context-mode"
      ]
    },
    "codebase-search": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "tooling",
        "python",
        "mcp/codebase_search.py"
      ]
    },
    "wave-db": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-server-fetch"
      ],
      "env": {
        "WAVE_DB_URL": "${WAVE_DB_URL}",
        "WAVE_DB_TOKEN": "${WAVE_DB_TOKEN}"
      }
    }
  }
}
